                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Dr. Sarah Smith\",\n  \"specialty\": \"Orthodontist\",\n  \"email\": \"sarah.smith@clinic.com\",\n  \"contact\": \"0300-1111111\",\n  \"bio\": \"Updated bio.\",\n  \"years_experience\": 11,\n  \"availability\": \"Mon, Wed, Fri\",\n  \"is_active\": true\n}"
                        }
                    }
                },
                {
                    "name": "DELETE dentist (soft delete)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/api/dentists/1"
                    }
                }
            ]
        },
        {
