                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/appointments",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"patient_id\": 1,\n  \"dentist_id\": 2,\n  \"appointment_date\": \"2026-03-10\",\n  \"appointment_time\": \"09:30\",\n  \"treatment_type\": \"Cavity Filling\",\n  \"notes\": \"Patient has mild sensitivity\"\n}"
                        }
                    }
                },
                {
                    "name": "PATCH update appointment status",
                    "request": {
                        "method": "PATCH",
                        "url": "{{baseUrl}}/api/appointments/1/status",
