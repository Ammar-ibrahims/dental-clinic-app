        {
            "name": "Dashboard Stats",
            "item": [
                {
                    "name": "GET dashboard stats",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/stats"
                    }
                }
            ]
        }
    ]
